{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run RSS Automation",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\RSS_Automation.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYDEVD_USE_SYS_MONITORING": "NO"
            }
        },
        {
            "name": "Run RSS Automation Loop",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\RSS_Automation.py",
            "args": [
                "--loop"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYDEVD_USE_SYS_MONITORING": "NO"
            }
        },
        {
            "name": "Run RSS Automation With Local Settings",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\RSS_Automation.py",
            "args": [
                "--settings",
                "${workspaceFolder}\\settings.json"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYDEVD_USE_SYS_MONITORING": "NO"
            }
        }
    ]
}
